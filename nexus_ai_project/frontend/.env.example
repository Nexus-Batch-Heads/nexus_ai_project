# Nexus AI – Environment Variables

# MongoDB (optional - app works without it using in-memory storage)
MONGODB_URI=mongodb://localhost:27017/nexus

# JWT Secret (change in production)
JWT_SECRET=nexus-super-secret-key-change-me-in-prod

# OpenAI API (optional - app works without it using mock AI)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Groq API (alternative to OpenAI, optional)
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
