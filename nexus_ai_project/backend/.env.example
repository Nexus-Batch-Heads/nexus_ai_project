# ── Nexus AI – Environment Variables ────────────────────────────
# Copy this file to .env and fill in the values.

# Flask
FLASK_ENV=development
SECRET_KEY=your-flask-secret-key
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ACCESS_TOKEN_HOURS=24

# MongoDB Atlas (Authentication)
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/nexus_ai_auth?retryWrites=true&w=majority

# MS SQL Server (Application Data)
MSSQL_URI=mssql+pyodbc://<user>:<password>@<server>/<database>?driver=ODBC+Driver+17+for+SQL+Server

# AI API Keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxx

# File Uploads
MAX_CONTENT_LENGTH=16777216

# CORS
CORS_ORIGINS=http://localhost:3000
